# Intelligent-IOT — Phase 1 ingestion environment template
# Copy to .env and fill in secrets:  cp .env.example .env
# .env is gitignored; do NOT commit real keys.

# --- Required ---
# OpenAQ v3 API key. If unset, run_ingestion silently skips the OpenAQ
# producer and ingests Environment Canada (SWOB) only. Env Canada needs no key.
OPENAQ_API_KEY=

# --- Kafka / Schema Registry (defaults match docker-compose) ---
KAFKA_BOOTSTRAP=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_PARTITIONS=3

# --- Source scope ---
OPENAQ_LOCATION_IDS=7570
ENVCANADA_BBOX=-80.0,43.0,-78.0,44.5

# --- Poll cadence (seconds) ---
POLL_INTERVAL_OPENAQ=300
POLL_INTERVAL_ENVCANADA=300
POLL_INTERVAL_IQAIR=300

# --- Topics (override only if needed) ---
TOPIC_MEASUREMENTS=aq.measurements
TOPIC_DEADLETTER=aq.deadletter
TOPIC_OPENAQ_RAW=aq.openaq.raw
TOPIC_ENVCANADA_RAW=aq.envcanada.raw
TOPIC_IQAIR_RAW=aq.iqair.raw

# --- Consumer groups ---
GROUP_NORMALIZER=aq-normalizer
GROUP_SINK=aq-sink

# --- Sink output root (Parquet, date-partitioned) ---
SINK_DIR=data/stream/measurements
