{
  "type": "record",
  "name": "WeatherRecord",
  "fields": [
    {"name": "station_id", "type": "string"},
    {"name": "timestamp", "type": "string"},
    {"name": "wind_speed", "type": ["null","double"], "default": null},
    {"name": "wind_dir_deg", "type": ["null","double"], "default": null}
  ]
}
